    <!-- https://astrea.linkeddata.es/shapes#d5d448b48b27234e42127b0148c1e506 -->


    <NamedIndividual rdf:about="https://astrea.linkeddata.es/shapes#d5d448b48b27234e42127b0148c1e506">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#PropertyShape"/>
        <rdfs:label>Coordenada X (longitud) de la ubicación del campo.</rdfs:label>
        <rdfs:label>coordenada X</rdfs:label>
        <shacl:datatype rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <shacl:description>Coordenada X (longitud) de la ubicación del campo.</shacl:description>
        <shacl:name>coordenada X</shacl:name>
        <shacl:nodeKind rdf:resource="http://www.w3.org/ns/shacl#Literal"/>
        <shacl:path rdf:resource="https://example.org/partidos/coorX"/>
        <shacl:pattern>(\+|-)?([0-9]+(\.[0-9]*)?|\.[0-9]+)([Ee](\+|-)?[0-9]+)?|(\+|-)?INF|NaN</shacl:pattern>
    </NamedIndividual>
    


    <!-- https://astrea.linkeddata.es/shapes#d8396f65677588b842c570bf16460e57 -->


    <NamedIndividual rdf:about="https://astrea.linkeddata.es/shapes#d8396f65677588b842c570bf16460e57">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#PropertyShape"/>
        <rdfs:label>URI externa equivalente para el distrito (enlace a recurso LOD).</rdfs:label>
        <rdfs:label>same as distrito</rdfs:label>
        <shacl:datatype rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <shacl:description>URI externa equivalente para el distrito (enlace a recurso LOD).</shacl:description>
        <shacl:name>same as distrito</shacl:name>
        <shacl:nodeKind rdf:resource="http://www.w3.org/ns/shacl#Literal"/>
        <shacl:path rdf:resource="https://example.org/partidos/sameAsDistrito"/>
        <shacl:pattern>^(([^:/?#]+):)?(//([^/?#]*))?([^?#]*)(\?([^#]*))?(#(.*))?</shacl:pattern>
    </NamedIndividual>
    


