    <NamedIndividual rdf:about="https://astrea.linkeddata.es/shapes#a045b3d330fbd27c93e7be2f23fc2f72">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#PropertyShape"/>
        <rdfs:label>Código numérico identificador de la jornada.</rdfs:label>
