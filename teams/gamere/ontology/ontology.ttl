@prefix gamere: <http://example.org/def/gamere#> .
@prefix mod: <https://w3id.org/mod#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

gamere: a owl:Ontology ;
    mod:createdWith <https://chowlk.linkeddata.es/> .

gamere:codigoConcello a owl:DatatypeProperty ;
    rdfs:label "codigo concello" ;
    rdfs:domain gamere:Concello ;
    rdfs:range xsd:integer .

gamere:codigoProvincia a owl:DatatypeProperty ;
    rdfs:label "codigo provincia" ;
    rdfs:domain gamere:Provincia ;
    rdfs:range xsd:integer .

gamere:coordenadasX a owl:DatatypeProperty ;
    rdfs:label "coordenadas x" ;
    rdfs:domain gamere:Ubicacion ;
    rdfs:range xsd:float .

gamere:coordenadasY a owl:DatatypeProperty ;
    rdfs:label "coordenadas y" ;
    rdfs:domain gamere:Ubicacion ;
    rdfs:range xsd:float .

gamere:descripcion a owl:DatatypeProperty ;
    rdfs:label "descripcion" ;
    rdfs:domain gamere:Ubicacion ;
    rdfs:range xsd:string .

gamere:entorno a owl:DatatypeProperty ;
    rdfs:label "entorno" ;
    rdfs:domain gamere:Praia ;
    rdfs:range xsd:string .

gamere:estaEn a owl:ObjectProperty ;
    rdfs:label "esta en" ;
    rdfs:domain gamere:Praia ;
    rdfs:range gamere:Ubicacion .

gamere:lonxitude a owl:DatatypeProperty ;
    rdfs:label "lonxitude" ;
    rdfs:domain gamere:Praia ;
    rdfs:range xsd:integer .

gamere:nameConcello a owl:DatatypeProperty ;
    rdfs:label "name concello" ;
    rdfs:domain gamere:Concello ;
    rdfs:range xsd:string .

gamere:nameProvincia a owl:DatatypeProperty ;
    rdfs:label "name provincia" ;
    rdfs:domain gamere:Provincia ;
    rdfs:range xsd:string .

gamere:nomePraia a owl:DatatypeProperty ;
    rdfs:label "nome praia" ;
    rdfs:domain gamere:Praia ;
    rdfs:range xsd:string .

gamere:perteneceA a owl:ObjectProperty ;
    rdfs:label "pertenece a" ;
    rdfs:domain gamere:Concello ;
    rdfs:range gamere:Provincia .

gamere:situadaEn a owl:ObjectProperty ;
    rdfs:label "situada en" ;
    rdfs:domain gamere:Praia ;
    rdfs:range gamere:Concello .

gamere:tipoArena a owl:DatatypeProperty ;
    rdfs:label "tipo arena" ;
    rdfs:domain gamere:Praia ;
    rdfs:range xsd:string .

gamere:url rdf:type owl:DatatypeProperty ;
    rdfs:label "url" ;
    rdfs:domain gamere:Praia ;
    rdfs:range xsd:anyURI .

owl:sameAs rdf:type owl:DatatypeProperty ;
    rdfs:label "same as" ;
    rdfs:domain [ 
        rdf:type owl:Class ;
        owl:unionOf ( gamere:Concello gamere:Praia gamere:Provincia )
    ] ;
    rdfs:range xsd:anyURI .

gamere:Provincia a owl:Class ;
    rdfs:label "Provincia" .

gamere:Ubicacion a owl:Class ;
    rdfs:label "Ubicacion" .

gamere:Concello a owl:Class ;
    rdfs:label "Concello" .

gamere:Praia a owl:Class ;
    rdfs:label "Praia" .
